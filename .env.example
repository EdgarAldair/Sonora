# Copy to .env and fill in your values. Never commit .env.
SONORA_PORT=8100

# Default account seeded on first run. Change the password.
SONORA_USER=sonora
SONORA_PASSWORD=change-me
# Allow creating accounts from the app (1) or lock it down (0).
REGISTRATION_ENABLED=1

# YouTube cookies file (mounted at /cookies) to reduce bot checks. Optional.
COOKIES_FILE=/cookies/cookies.txt
# PO token provider (bgutil). Keep as-is for the bundled service.
POT_PROVIDER_URL=http://bgutil-provider:4416

# Optional Lidarr integration for lossless (FLAC) requests.
LIDARR_URL=
LIDARR_API_KEY=
LIDARR_QUALITY_PROFILE=2

# ---- Alexa skill (optional). Leave blank to disable. ----
# Public HTTPS URL of this server (Alexa fetches stream URLs from it).
PUBLIC_BASE_URL=https://your-server.example.com
# Your skill id. When set, the /alexa endpoint only accepts that skill.
ALEXA_SKILL_ID=
# Fallback Sonora account used when a user has not linked their own.
ALEXA_USER=
# OAuth credentials for Account Linking. Put the same values in the Alexa console.
# Generate the secret with: openssl rand -hex 24
ALEXA_CLIENT_ID=sonora-alexa
ALEXA_CLIENT_SECRET=change-me
# Session token for the fallback account. Generate with: openssl rand -hex 24
ALEXA_TOKEN=change-me

# Path on the host to your music library (mounted at /music).
MUSIC_DIR=./music
